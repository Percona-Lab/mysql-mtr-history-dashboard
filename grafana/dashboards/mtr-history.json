                            "color": "#FFCC02"
                          }
                        }
                      },
                      {
                        "type": "value",
                        "options": {
                          "FAILURE": {
                            "color": "#F2495C"
                          }
                        }
                      },
                      {
                        "type": "value",
                        "options": {
