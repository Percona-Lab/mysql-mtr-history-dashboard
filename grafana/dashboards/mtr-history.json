{
  "title": "MySQL MTR History",
  "uid": "mtr-history",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "style": "dark",
  "tags": [
    "mtr",
    "percona",
    "test-history"
  ],
  "liveNow": false,
  "refresh": "",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [],
    "time_options": [
      "30m",
      "2h",
      "6h",
      "24h",
      "7d",
      "30d",
      "90d",
      "180d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "PBFA97CFB590B2093"
        },
        "hide": 0
      },
      {
        "name": "platform_os",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info, platform_os)",
          "refId": "vPlatformOS"
        },
        "includeAll": false,
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "oraclelinux-10"
          ],
          "value": [
            "oraclelinux-10"
          ]
        },
        "label": "OS"
      },
      {
        "name": "platform_build",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\"}, platform_build)",
          "refId": "vPlatformBuild"
        },
        "includeAll": false,
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "Debug"
          ],
          "value": [
            "Debug"
          ]
        },
        "label": "Build"
      },
      {
        "name": "arch",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\"}, arch)",
          "refId": "vArch"
        },
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": "x86_64",
          "value": "x86_64"
        },
        "label": "Arch"
      },
      {
        "name": "branch",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\", arch=\"$arch\"}, branch)",
          "refId": "vBranch"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Branch"
      },
      {
        "name": "fork",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\", arch=\"$arch\"}, fork)",
          "refId": "vFork"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Fork"
      },
      {
        "name": "test_suite",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_test_status{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\"}, suite)",
          "refId": "vSuite"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Suite"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 2,
      "type": "row",
      "title": "Failure matrix -- tests x builds",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 20,
      "type": "table",
      "title": "Failure matrix -- tests x builds",
      "description": "Each row = a failing test. Red blocks = builds where it failed. Gaps = passed. Click to open Jenkins.",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "maxDataPoints": 200,
      "interval": "3d",
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(mtr_test_failure_info{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\",suite=~\"$test_suite\"}[$__range])",
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": true,
          "reducer": [
            "count"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Test"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open testReport in Jenkins",
                    "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__data.fields.Build}/testReport/${__data.fields.OS}.${__data.fields.Type}.${__data.fields.Worker}/${__data.fields.Suite}/${__value.raw}/",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Build"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open build in Jenkins",
                    "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__value.raw}/",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Error"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 400
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job_name": true,
              "build": true,
              "arch": true,
              "fork": true,
              "Value": true
            },
            "renameByName": {
              "suite": "Suite",
              "testname": "Test",
              "build_n": "Build",
              "run_context": "Context",
              "worker_slug": "Worker",
              "platform_os": "OS",
              "platform_build": "Type",
              "worker_num": "W#",
              "branch": "Branch",
              "failure_msg": "Error"
            },
            "indexByName": {
              "build_n": 0,
              "suite": 1,
              "testname": 2,
              "run_context": 3,
              "worker_slug": 4,
              "platform_os": 5,
              "platform_build": 6,
              "worker_num": 7,
              "branch": 8,
              "failure_msg": 9
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Build",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "collapsed": true,
      "panels": [
        {
          "id": 40,
          "type": "timeseries",
          "title": "Failures per build",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 21
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "maxDataPoints": 10000,
          "interval": "1m",
          "targets": [
            {
              "refId": "A",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 0)",
              "legendFormat": "{{build}}",
              "interval": "1m"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "fixed",
                "fixedColor": "red"
              },
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 80
              },
              "unit": "short"
            }
          }
        },
        {
          "id": 41,
          "type": "timeseries",
          "title": "Pass / Fail / Skip (failing builds only)",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 29
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "maxDataPoints": 10000,
          "interval": "1m",
          "targets": [
            {
              "refId": "P",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 1)",
              "legendFormat": "pass",
              "interval": "1m"
            },
            {
              "refId": "F",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 0)",
              "legendFormat": "fail",
              "interval": "1m"
            },
            {
              "refId": "S",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 2)",
              "legendFormat": "skip",
              "interval": "1m"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "bars",
                "stacking": {
                  "mode": "normal"
                },
                "fillOpacity": 80
              },
              "unit": "short"
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "pass"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#73BF69"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "fail"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#F2495C"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "skip"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#B0B0B0"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Analysis",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "collapsed": true,
      "panels": [
        {
          "id": 50,
          "type": "table",
          "title": "Top-20 flakiest tests",
          "gridPos": {
            "h": 10,
            "w": 12,
            "x": 0,
            "y": 38
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "targets": [
            {
              "refId": "A",
              "expr": "topk(20, count by (suite, testname) (last_over_time(mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}[$__range]) == 0))",
              "format": "table",
              "instant": true,
              "range": false
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "Value": "Fails"
                }
              }
            },
            {
              "id": "sortBy",
              "options": {
                "fields": {},
                "sort": [
                  {
                    "field": "Fails",
                    "desc": true
                  }
                ]
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "align": "left"
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Fails"
                },
                "properties": [
                  {
                    "id": "custom.cellOptions",
                    "value": {
                      "type": "color-background"
                    }
                  },
                  {
                    "id": "color",
                    "value": {
                      "mode": "continuous-YlOrRd"
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "id": 51,
          "type": "table",
          "title": "Build details",
          "gridPos": {
            "h": 10,
            "w": 12,
            "x": 12,
            "y": 48
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "maxDataPoints": 10000,
          "interval": "1m",
          "targets": [
            {
              "refId": "A",
              "expr": "mtr_build_info{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}",
              "format": "table",
              "instant": false,
              "interval": "1m"
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "Time": "When",
                  "build": "Build #",
                  "result": "Result",
                  "cause_kind": "Trigger",
                  "cause_user": "User",
                  "branch": "Branch",
                  "fork": "Fork"
                },
                "excludeByName": {
                  "Value": true,
                  "__name__": true,
                  "instance": true,
                  "job_name": true,
                  "arch": true,
                  "platform_os": true,
                  "platform_build": true,
                  "build_url": false
                }
              }
            },
            {
              "id": "sortBy",
              "options": {
                "fields": {},
                "sort": [
                  {
                    "field": "When",
                    "desc": true
                  }
                ]
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "align": "left"
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Build #"
                },
                "properties": [
                  {
                    "id": "links",
                    "value": [
                      {
                        "title": "Open Jenkins",
                        "url": "${__data.fields.build_url}",
                        "targetBlank": true
                      }
                    ]
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "Result"
                },
                "properties": [
                  {
                    "id": "mappings",
                    "value": [
                      {
                        "type": "value",
                        "options": {
                          "SUCCESS": {
                            "color": "#73BF69"
                          }
                        }
                      },
                      {
                        "type": "value",
                        "options": {
                          "UNSTABLE": {
                            "color": "#FFCC02"
                          }
                        }
                      },
                      {
                        "type": "value",
                        "options": {
                          "FAILURE": {
                            "color": "#F2495C"
                          }
                        }
                      },
                      {
                        "type": "value",
                        "options": {
                          "ABORTED": {
                            "color": "#B0B0B0"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "id": "custom.cellOptions",
                    "value": {
                      "type": "color-text"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
