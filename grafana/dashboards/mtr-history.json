    {
      "id": 5,
      "type": "row",
      "title": "Analysis",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "collapsed": true,
      "panels": [
        {
          "id": 50,
          "type": "table",
          "title": "Top-20 flakiest tests",
          "gridPos": {
            "h": 10,
            "w": 12,
            "x": 0,
