{
  "title": "MySQL MTR History",
  "uid": "mtr-history",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "style": "dark",
  "tags": [
    "mtr",
    "percona",
    "test-history"
  ],
  "liveNow": false,
  "refresh": "",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [],
    "time_options": [
      "30m",
      "2h",
      "6h",
      "24h",
      "7d",
      "30d",
      "90d",
      "180d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "PBFA97CFB590B2093"
        },
        "hide": 0
      },
      {
        "name": "platform_os",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info, platform_os)",
          "refId": "vPlatformOS"
        },
        "includeAll": false,
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "oraclelinux-10"
          ],
          "value": [
            "oraclelinux-10"
          ]
        },
        "label": "OS"
      },
      {
        "name": "platform_build",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\"}, platform_build)",
          "refId": "vPlatformBuild"
        },
        "includeAll": false,
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "Debug"
          ],
          "value": [
            "Debug"
          ]
        },
        "label": "Build Type"
      },
      {
        "name": "arch",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\"}, arch)",
          "refId": "vArch"
        },
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": "x86_64",
          "value": "x86_64"
        },
        "label": "Arch"
      },
      {
        "name": "branch",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\", arch=\"$arch\"}, branch)",
          "refId": "vBranch"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Branch"
      },
      {
        "name": "fork",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\", arch=\"$arch\"}, fork)",
          "refId": "vFork"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Fork"
      },
      {
        "name": "test_suite",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_test_status{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\"}, suite)",
          "refId": "vSuite"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Suite"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 2,
      "type": "row",
      "title": "Failure matrix -- tests x builds",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 20,
      "type": "table",
      "title": "Failure matrix -- tests x builds",
      "description": "Each row = a failing test. Red blocks = builds where it failed. Gaps = passed. Click to open Jenkins.",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "maxDataPoints": 200,
      "interval": "3d",
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(mtr_test_failure_info{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\",suite=~\"$test_suite\"}[200d])",
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": true,
          "reducer": [
            "count"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Test"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open build in Jenkins",
                    "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__data.fields.Build}/testReport/",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Build"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open build in Jenkins",
                    "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__value.raw}/",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Error"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 400
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job_name": true,
              "build": true,
              "Value": true,
              "platform_os": true,
              "platform_build": true,
              "arch": true,
              "fork": true,
              "run_context": true,
              "worker_num": true
            },
            "renameByName": {
              "suite": "Suite",
              "testname": "Test",
              "build_n": "Build",
              "worker_slug": "Worker",
              "branch": "Branch",
              "failure_msg": "Error"
            },
            "indexByName": {
              "build_n": 0,
              "suite": 1,
              "testname": 2,
              "worker_slug": 3,
              "branch": 4,
              "failure_msg": 5
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Build",
                "desc": true
              }
            ]
          }
        }
      ]
    }
  ]
}
