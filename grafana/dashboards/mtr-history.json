{
  "title": "MySQL MTR History",
  "uid": "mtr-history",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "style": "dark",
  "tags": [
    "mtr",
    "percona",
    "test-history"
  ],
  "liveNow": false,
  "refresh": "",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [],
    "time_options": [
      "30m",
      "2h",
      "6h",
      "24h",
      "7d",
      "30d",
      "90d",
      "180d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "PBFA97CFB590B2093"
        },
        "hide": 0
      },
      {
        "name": "platform_os",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info, platform_os)",
          "refId": "vPlatformOS"
        },
        "includeAll": false,
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "oraclelinux-10"
          ],
          "value": [
            "oraclelinux-10"
          ]
        },
        "label": "OS"
      },
      {
        "name": "platform_build",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\"}, platform_build)",
          "refId": "vPlatformBuild"
        },
        "includeAll": false,
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "Debug"
          ],
          "value": [
            "Debug"
          ]
        },
        "label": "Build"
      },
      {
        "name": "arch",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\"}, arch)",
          "refId": "vArch"
        },
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": "x86_64",
          "value": "x86_64"
        },
        "label": "Arch"
      },
      {
        "name": "branch",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\", arch=\"$arch\"}, branch)",
          "refId": "vBranch"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Branch"
      },
      {
        "name": "fork",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\", arch=\"$arch\"}, fork)",
          "refId": "vFork"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Fork"
      },
      {
        "name": "test_suite",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_test_status{platform_os=~\"$platform_os\", platform_build=~\"$platform_build\"}, suite)",
          "refId": "vSuite"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "label": "Suite"
      },
      {
        "name": "show_only",
        "type": "custom",
        "description": "Filter fragment appended to the hero-matrix PromQL expression",
        "options": [
          {
            "text": "all",
            "value": "",
            "selected": false
          },
          {
            "text": "failures only",
            "value": "== 0",
            "selected": true
          },
          {
            "text": "skips only",
            "value": "== 2",
            "selected": false
          },
          {
            "text": "passes only",
            "value": "== 1",
            "selected": false
          }
        ],
        "current": {
          "text": "failures only",
          "value": "== 0"
        },
        "label": "Show"
      },
      {
        "name": "build",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROM}"
        },
        "query": {
          "query": "label_values(mtr_build_info{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}, build)",
          "refId": "vBuild"
        },
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 4,
        "current": {
          "text": "01558",
          "value": "01558"
        },
        "label": "Build"
      },
      {
        "name": "selected_suite",
        "type": "textbox",
        "current": {
          "text": "audit_log",
          "value": "audit_log"
        },
        "label": "Drill-down: suite"
      },
      {
        "name": "selected_testname",
        "type": "textbox",
        "current": {
          "text": "audit_log_charset",
          "value": "audit_log_charset"
        },
        "label": "Drill-down: testname"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Failing builds in range",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(group by (build) (count_over_time(mtr_build_info{result=~\"UNSTABLE|FAILURE|ABORTED\",platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}[$__range])))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "#FF9830"
          },
          "mappings": []
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Avg failures / build",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(count by (build) (last_over_time(mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\",suite=~\"$test_suite\"}[$__range]) == 0))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#F2CC0C",
                "value": 2
              },
              {
                "color": "#FA6400",
                "value": 5
              },
              {
                "color": "#E02F44",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Fail count (in range)",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(last_over_time(mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\",suite=~\"$test_suite\"}[$__range]) == 0)",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#56A64B",
                "value": null
              },
              {
                "color": "#F2CC0C",
                "value": 1
              },
              {
                "color": "#FA6400",
                "value": 10
              },
              {
                "color": "#E02F44",
                "value": 50
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Flaky tests",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count((count by (suite, testname) (last_over_time(mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}[$__range]) == 0) > 0) and (count by (suite, testname) (last_over_time(mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}[$__range]) == 1) > 0))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#56A64B",
                "value": null
              },
              {
                "color": "#F2CC0C",
                "value": 1
              },
              {
                "color": "#FA6400",
                "value": 5
              },
              {
                "color": "#E02F44",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Longest test p99",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile(0.99, max_over_time(mtr_test_duration_seconds{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}[$__range]))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#8AB8FF"
          }
        }
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Unique tests",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (suite, testname) (last_over_time(mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}[$__range])))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "#B877D9"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Hero matrix \u2014 tests \u00d7 time",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "state-timeline",
      "title": "Failure matrix -- tests x builds",
      "description": "Each row = a failing test. Red blocks = builds where it failed. Gaps = passed. Click to open Jenkins.",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "maxDataPoints": 5000,
      "interval": "1h",
      "targets": [
        {
          "refId": "A",
          "expr": "mtr_test_failure_info{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\",suite=~\"$test_suite\"}",
          "legendFormat": "{{suite}}/{{testname}} [{{worker_slug}}]",
          "range": true,
          "instant": false,
          "interval": "1h"
        }
      ],
      "options": {
        "mergeValues": false,
        "showValue": "never",
        "rowHeight": 0.85,
        "alignValue": "center",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none",
          "maxWidth": 500
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 100
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "FAIL",
                  "color": "#E02F44",
                  "index": 0
                }
              }
            }
          ],
          "links": [
            {
              "title": "Open testReport in Jenkins",
              "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__field.labels.build_n}/testReport/${__field.labels.platform_os}.${__field.labels.platform_build}.${__field.labels.worker_slug}/${__field.labels.suite}/${__field.labels.testname}/",
              "targetBlank": true
            },
            {
              "title": "Open build #${__field.labels.build_n}",
              "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__field.labels.build_n}/",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "transformations": []
    },
    {
      "id": 3,
      "type": "row",
      "title": "Info box \u2014 $selected_suite.$selected_testname across platforms",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false
    },
    {
      "id": 30,
      "type": "state-timeline",
      "title": "$selected_suite.$selected_testname \u2014 per-platform timeline",
      "description": "State-timeline of the selected test across every platform and run_context we've ingested (respects $branch / $fork).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "maxDataPoints": 5000,
      "interval": "1h",
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(mtr_test_status{suite=\"$selected_suite\", testname=\"$selected_testname\", branch=~\"$branch\", fork=~\"$fork\"}[24h])",
          "legendFormat": "{{platform_os}}/{{platform_build}} {{run_context}}:{{worker_slug}}",
          "range": true,
          "instant": false,
          "interval": "1h"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 100
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "PASS",
                  "color": "#56A64B",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "#E02F44",
                  "index": 1
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "SKIP",
                  "color": "#7B7B7B",
                  "index": 2
                }
              }
            }
          ],
          "links": [
            {
              "title": "Open Jenkins build",
              "url": "https://${__field.labels.instance}/job/${__field.labels.job_name}/${__field.labels.build_n}/",
              "targetBlank": true
            },
            {
              "title": "Open testReport",
              "url": "https://${__field.labels.instance}/job/${__field.labels.job_name}/${__field.labels.build_n}/testReport/${__field.labels.platform_os}.${__field.labels.platform_build}.${__field.labels.worker_slug}/${__field.labels.suite}/${__field.labels.testname}/",
              "targetBlank": true
            }
          ]
        }
      }
    },
    {
      "id": 31,
      "type": "table",
      "title": "$selected_suite.$selected_testname \u2014 per-build detail",
      "description": "One row per (build, platform, run_context) for the selected test.  Click Build # to open Jenkins.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(mtr_test_status{suite=\"$selected_suite\", testname=\"$selected_testname\", branch=~\"$branch\", fork=~\"$fork\"}[$__range])",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Time": "When",
              "build": "Build #",
              "platform_os": "OS",
              "platform_build": "Build type",
              "arch": "Arch",
              "run_context": "Context",
              "worker_slug": "Worker",
              "Value": "Status"
            },
            "excludeByName": {
              "__name__": true,
              "instance": true,
              "job_name": true,
              "suite": true,
              "testname": true,
              "big": true,
              "fork": true,
              "branch": true,
              "worker_num": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "When",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "\u2713 PASS",
                  "color": "#73BF69"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "\u2717 FAIL",
                  "color": "#F2495C"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "\u2022 SKIP",
                  "color": "#B0B0B0"
                }
              }
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background-solid"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Build #"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open Jenkins build",
                    "url": "https://ps80.cd.percona.com/job/percona-server-8.0-pipeline-parallel-mtr/${__value.raw}/",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "collapsed": true,
      "panels": [
        {
          "id": 40,
          "type": "timeseries",
          "title": "Failures per build",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 33
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "maxDataPoints": 10000,
          "interval": "1m",
          "targets": [
            {
              "refId": "A",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 0)",
              "legendFormat": "{{build}}",
              "interval": "1m"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "fixed",
                "fixedColor": "red"
              },
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 80
              },
              "unit": "short"
            }
          }
        },
        {
          "id": 41,
          "type": "timeseries",
          "title": "Pass / Fail / Skip (failing builds only)",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 33
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "maxDataPoints": 10000,
          "interval": "1m",
          "targets": [
            {
              "refId": "P",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 1)",
              "legendFormat": "pass",
              "interval": "1m"
            },
            {
              "refId": "F",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 0)",
              "legendFormat": "fail",
              "interval": "1m"
            },
            {
              "refId": "S",
              "expr": "count by (build) (mtr_test_status{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"} == 2)",
              "legendFormat": "skip",
              "interval": "1m"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "bars",
                "stacking": {
                  "mode": "normal"
                },
                "fillOpacity": 80
              },
              "unit": "short"
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "pass"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#73BF69"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "fail"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#F2495C"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "skip"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#B0B0B0"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
