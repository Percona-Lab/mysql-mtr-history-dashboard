          "transformations": [
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "Value": "Fails"
                }
              }
            },
            {
              "id": "sortBy",
              "options": {
                "fields": {},
                "sort": [
                  {
                    "field": "Fails",
                    "desc": true
                  }
                ]
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "align": "left"
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Fails"
                },
                "properties": [
                  {
                    "id": "custom.cellOptions",
                    "value": {
                      "type": "color-background"
                    }
                  },
                  {
                    "id": "color",
                    "value": {
                      "mode": "continuous-YlOrRd"
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "id": 51,
          "type": "table",
          "title": "Build details",
          "gridPos": {
            "h": 10,
            "w": 12,
            "x": 12,
            "y": 35
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "maxDataPoints": 10000,
          "interval": "1m",
          "targets": [
            {
              "refId": "A",
              "expr": "mtr_build_info{platform_os=~\"$platform_os\",platform_build=~\"$platform_build\",arch=\"$arch\",branch=~\"$branch\",fork=~\"$fork\"}",
              "format": "table",
              "instant": false,
              "interval": "1m"
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "Time": "When",
                  "build": "Build #",
                  "result": "Result",
                  "cause_kind": "Trigger",
                  "cause_user": "User",
                  "branch": "Branch",
                  "fork": "Fork"
                },
                "excludeByName": {
                  "Value": true,
                  "__name__": true,
                  "instance": true,
                  "job_name": true,
                  "arch": true,
                  "platform_os": true,
                  "platform_build": true,
                  "build_url": false
                }
              }
            },
            {
              "id": "sortBy",
              "options": {
                "fields": {},
                "sort": [
                  {
                    "field": "When",
                    "desc": true
                  }
                ]
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "align": "left"
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Build #"
                },
                "properties": [
                  {
                    "id": "links",
